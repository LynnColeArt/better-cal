{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cal.diy/contracts/schemas/secret-registry.schema.json",
  "title": "Secret Registry",
  "type": "object",
  "required": ["status", "description", "secrets"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "status": { "type": "string" },
    "description": { "type": "string" },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "fieldNames", "class", "storage", "responseRule", "logRule", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "fieldNames": { "type": "array", "items": { "type": "string" } },
          "class": { "type": "string" },
          "storage": { "type": "string" },
          "responseRule": { "type": "string" },
          "logRule": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
