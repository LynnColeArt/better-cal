{
  "$schema": "../schemas/secret-registry.schema.json",
  "status": "draft",
  "description": "Initial secret classification registry.",
  "secrets": [
    {
      "id": "secret.http.authorization",
      "fieldNames": ["Authorization", "authorization"],
      "class": "input-only",
      "storage": "not-stored",
      "responseRule": "never-return",
      "logRule": "redact-entire-value",
      "notes": "Bearer credentials must not appear in logs, fixtures, or errors."
    },
    {
      "id": "secret.http.cookie",
      "fieldNames": ["Cookie", "cookie", "set-cookie", "session"],
      "class": "input-only",
      "storage": "not-stored",
      "responseRule": "never-return",
      "logRule": "redact-entire-value",
      "notes": "Session material is never a service identity source without server-side verification."
    },
    {
      "id": "secret.apiKey.plaintext",
      "fieldNames": ["apiKey", "key", "plainTextKey"],
      "class": "show-once",
      "storage": "hash-only",
      "responseRule": "creation-or-refresh-only",
      "logRule": "redact-entire-value",
      "notes": "API keys may be shown only at creation or refresh."
    },
    {
      "id": "secret.oauth.clientSecret",
      "fieldNames": ["client_secret", "clientSecret", "x-cal-secret-key"],
      "class": "show-once",
      "storage": "hash-preferred",
      "responseRule": "creation-or-rotation-only",
      "logRule": "redact-entire-value",
      "notes": "Existing secrets must not be returned by list, get, update, or delete."
    },
    {
      "id": "secret.oauth.accessToken",
      "fieldNames": ["accessToken", "access_token"],
      "class": "show-once",
      "storage": "encrypted-or-hashed-by-use",
      "responseRule": "token-endpoint-only",
      "logRule": "redact-entire-value",
      "notes": "Bearer token value."
    },
    {
      "id": "secret.oauth.refreshToken",
      "fieldNames": ["refreshToken", "refresh_token"],
      "class": "show-once",
      "storage": "encrypted-or-hashed-by-use",
      "responseRule": "token-endpoint-only",
      "logRule": "redact-entire-value",
      "notes": "Replay and rotation behavior must be tested."
    },
    {
      "id": "secret.provider.credential",
      "fieldNames": ["credential", "credentials", "providerToken", "encryptedKey", "refresh_token", "access_token"],
      "class": "internal-only",
      "storage": "encrypted",
      "responseRule": "never-return",
      "logRule": "redact-entire-value",
      "notes": "Provider credentials stay behind provider ports."
    },
    {
      "id": "secret.webhook.secret",
      "fieldNames": ["webhookSecret", "secret"],
      "class": "input-only",
      "storage": "encrypted-or-hashed-by-use",
      "responseRule": "never-return-unless-approved-show-once",
      "logRule": "redact-entire-value",
      "notes": "Outbound signing secret and inbound verification secret."
    },
    {
      "id": "secret.password",
      "fieldNames": ["password", "newPassword", "currentPassword"],
      "class": "input-only",
      "storage": "hash-only",
      "responseRule": "never-return",
      "logRule": "redact-entire-value",
      "notes": "Plaintext password values never leave request handling."
    },
    {
      "id": "secret.cron.signature",
      "fieldNames": ["x-cal-cron-signature", "x-vercel-signature", "signature"],
      "class": "input-only",
      "storage": "not-stored",
      "responseRule": "never-return",
      "logRule": "redact-entire-value",
      "notes": "Cron and webhook trigger authentication must not use query-string secrets."
    }
  ]
}
